# Vercel 本番用環境変数テンプレート
# このファイルを .env.production にコピーしてからローカルで `npm run build` するか、
# Vercel ダッシュボードの Settings → Environment Variables に同じキーを登録する。

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# RTMPose API サーバ（Hugging Face Spaces の URL）
# 例: https://taroyamada-pose-server.hf.space
VITE_RTMPOSE_API_URL=https://your-username-your-space.hf.space

# OpenAI（任意、AI アドバイス機能用）
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://www.genspark.ai/api/llm_proxy/v1
